# ChatHQ Environment Variables
# Copy this file to .env and fill in your values

# MongoDB connection string (required)
MONGO_URI=mongodb+srv://youruser:yourpassword@cluster.mongodb.net/chathq

# General chat password (users need this to join)
GENERAL_PASS=chat123

# Admin panel password (keep this secret!)
ADMIN_PASS=supersecretadmin

# Port (optional, defaults to 3000)
PORT=3000
